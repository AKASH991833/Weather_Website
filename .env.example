# WeatherNow Backend - Environment Variables

# Copy this file to .env and fill in your API key

# Get your API key from: https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Server port (optional, defaults to 3001)
PORT=3001

# Node environment (optional)
NODE_ENV=development

# CORS Allowed Origins (comma-separated URLs, no spaces)
# Example: http://localhost:3000,https://yourdomain.com,https://your-app.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Rate limiting (optional, defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Cache TTL in seconds (optional, defaults to 600)
# CACHE_TTL=600
